# ============================================================================
# TrueVow SETTLE™ Service - Environment Configuration Template
# ============================================================================
# Copy this file to .env and update with your actual values
# Version: 1.0.0 (5-Service Enterprise Architecture)
# Last Updated: January 3, 2026

# ============================================================================
# SERVICE CONFIGURATION
# ============================================================================
SERVICE_NAME="truevow-settle-service"
SERVICE_PORT=8002
SERVICE_VERSION="1.0.0"
ENVIRONMENT="development"  # development | staging | production
DEBUG=True

# Application Settings
APP_NAME="TrueVow SETTLE Service"
APP_DESCRIPTION="Attorney-owned settlement database service"

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL (Primary)
DATABASE_URL="postgresql://user:password@localhost:5432/settle_db"
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=False  # Set to True for SQL query logging

# Or use Supabase (Alternative)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_KEY="your-supabase-service-key"

# ============================================================================
# REDIS CONFIGURATION (Caching & Rate Limiting)
# ============================================================================
REDIS_URL="redis://localhost:6379/0"
REDIS_CACHE_TTL=3600  # 1 hour
REDIS_MAX_CONNECTIONS=50

# ============================================================================
# SECURITY & AUTHENTICATION
# ============================================================================
SECRET_KEY="change-me-in-production-use-strong-random-key"
API_KEY_SALT="change-me-in-production-use-strong-random-salt"
JWT_SECRET_KEY="change-me-in-production-jwt-secret"
JWT_ALGORITHM="HS256"
JWT_EXPIRATION_HOURS=24

# Admin API Key (for Platform Service)
SETTLE_ADMIN_API_KEY="settle_admin_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ============================================================================
# SERVICE-TO-SERVICE INTEGRATION (5-Service Architecture)
# ============================================================================

# Platform Service (Tenant Management, Billing, Integration Gateway)
PLATFORM_SERVICE_URL="http://localhost:3000"
PLATFORM_SERVICE_API_KEY="platform_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
PLATFORM_SERVICE_TIMEOUT=30

# Internal Ops Service (Task Management, Time Tracking, Notifications)
INTERNAL_OPS_SERVICE_URL="http://localhost:3001"
INTERNAL_OPS_SERVICE_API_KEY="internal_ops_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
INTERNAL_OPS_SERVICE_TIMEOUT=30

# Sales Service (Pipeline Management, Lead Qualification, Demos)
SALES_SERVICE_URL="http://localhost:3002"
SALES_SERVICE_API_KEY="sales_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
SALES_SERVICE_TIMEOUT=30

# Support Service (Tickets, Shared Inbox, Knowledge Base)
SUPPORT_SERVICE_URL="http://localhost:3003"
SUPPORT_SERVICE_API_KEY="support_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
SUPPORT_SERVICE_TIMEOUT=30

# Tenant Service (INTAKE, DRAFT, BILLING, Appointments, Leads)
TENANT_SERVICE_URL="http://localhost:8000"
TENANT_SERVICE_API_KEY="tenant_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TENANT_SERVICE_TIMEOUT=30

# ============================================================================
# EMAIL SERVICE (SendGrid)
# ============================================================================
SENDGRID_API_KEY="SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
SENDGRID_FROM_EMAIL="noreply@truevow.law"
SENDGRID_FROM_NAME="TrueVow SETTLE"
SENDGRID_REPLY_TO="support@truevow.law"

# Email Templates
SENDGRID_TEMPLATE_WELCOME="d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
SENDGRID_TEMPLATE_CONTRIBUTION_APPROVED="d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
SENDGRID_TEMPLATE_CONTRIBUTION_REJECTED="d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
SENDGRID_TEMPLATE_REPORT_READY="d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ============================================================================
# AWS S3 (Report Storage)
# ============================================================================
AWS_ACCESS_KEY_ID="AKIAXXXXXXXXXXXXX"
AWS_SECRET_ACCESS_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
AWS_S3_BUCKET="truevow-settle-reports"
AWS_REGION="us-west-2"
AWS_S3_PRESIGNED_URL_EXPIRATION=604800  # 7 days

# ============================================================================
# STRIPE (Billing Integration)
# ============================================================================
STRIPE_API_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
STRIPE_PRICE_ID_STANDARD="price_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
STRIPE_PRICE_ID_PREMIUM="price_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ============================================================================
# OPENTIMESTAMPS (Blockchain Verification)
# ============================================================================
OTS_CALENDAR_URL="https://alice.btc.calendar.opentimestamps.org"
OTS_ENABLE_VERIFICATION=True

# ============================================================================
# FEATURE FLAGS
# ============================================================================
ENABLE_FOUNDING_MEMBER_PROGRAM=True
ENABLE_WAITLIST=True
ENABLE_PDF_REPORTS=True
ENABLE_BLOCKCHAIN_VERIFICATION=True
ENABLE_EMAIL_NOTIFICATIONS=True
ENABLE_SLACK_NOTIFICATIONS=False

# ============================================================================
# RATE LIMITING (Requests per minute)
# ============================================================================
RATE_LIMIT_FOUNDING_MEMBER=100
RATE_LIMIT_PREMIUM=50
RATE_LIMIT_STANDARD=10
RATE_LIMIT_EXTERNAL=5
RATE_LIMIT_ADMIN=1000

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
CORS_ORIGINS="http://localhost:3000,http://localhost:8000,https://app.truevow.law,https://admin.truevow.law"
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS="GET,POST,PUT,DELETE,OPTIONS"
CORS_ALLOW_HEADERS="*"

# ============================================================================
# LOGGING & MONITORING
# ============================================================================
LOG_LEVEL="INFO"  # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT="json"  # json | text
LOG_FILE="logs/settle_service.log"

# Sentry (Error Tracking)
SENTRY_DSN="https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxx@sentry.io/xxxxx"
SENTRY_ENVIRONMENT="development"
SENTRY_TRACES_SAMPLE_RATE=0.1

# Slack (Alerts)
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
SLACK_CHANNEL="#settle-alerts"

# ============================================================================
# PERFORMANCE & OPTIMIZATION
# ============================================================================
ENABLE_QUERY_CACHE=True
QUERY_CACHE_TTL=300  # 5 minutes
MAX_COMPARABLE_CASES=50
QUERY_TIMEOUT_SECONDS=30

# ============================================================================
# TESTING & DEVELOPMENT
# ============================================================================
# Test API Key (for integration tests)
SETTLE_TEST_API_KEY="settle_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Mock External Services (for testing)
MOCK_PLATFORM_SERVICE=False
MOCK_INTERNAL_OPS_SERVICE=False
MOCK_EMAIL_SERVICE=False
MOCK_STRIPE_SERVICE=False

# ============================================================================
# DEPLOYMENT CONFIGURATION
# ============================================================================
# Docker
DOCKER_IMAGE="truevow/settle-service:latest"
DOCKER_REGISTRY="ghcr.io"

# Health Check
HEALTH_CHECK_INTERVAL=30  # seconds
HEALTH_CHECK_TIMEOUT=10  # seconds

# Graceful Shutdown
SHUTDOWN_TIMEOUT=30  # seconds

# ============================================================================
# See full configuration options in app/core/config.py
# ============================================================================

